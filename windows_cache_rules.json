{
  "version": "1.1.0",
  "platform": "windows",
  "description": "Cache scanning rules for common Windows desktop applications, including Chinese domestic software.",
  "variables": {
    "%USERPROFILE%": "C:\\Users\\{username}",
    "%LOCALAPPDATA%": "C:\\Users\\{username}\\AppData\\Local",
    "%APPDATA%": "C:\\Users\\{username}\\AppData\\Roaming",
    "%PROGRAMFILES%": "C:\\Program Files",
    "%PROGRAMFILES(X86)%": "C:\\Program Files (x86)",
    "%TEMP%": "C:\\Users\\{username}\\AppData\\Local\\Temp"
  },
  "global_rules": {
    "default_follow_symlink": false,
    "default_include_hidden": true,
    "default_min_file_age_minutes": 10,
    "default_exclude_extensions": [
      ".db",
      ".sqlite",
      ".sqlite3",
      ".ldb",
      ".sst",
      ".logdb"
    ],
    "default_exclude_file_names": [
      "Bookmarks",
      "Bookmarks.bak",
      "Cookies",
      "Cookies-journal",
      "Current Session",
      "Current Tabs",
      "Favicons",
      "History",
      "History-journal",
      "Last Session",
      "Last Tabs",
      "Login Data",
      "Login Data For Account",
      "Network Persistent State",
      "Preferences",
      "Secure Preferences",
      "Session Storage",
      "Top Sites",
      "Visited Links",
      "Web Data"
    ],
    "safe_dir_name_patterns": [
      "Cache",
      "Caches",
      "Code Cache",
      "GPUCache",
      "GrShaderCache",
      "ShaderCache",
      "Temp",
      "Tmp",
      "Logs",
      "Crashpad",
      "CrashDumps",
      "Dumps",
      "blob_storage",
      "Service Worker\\CacheStorage"
    ]
  },
  "apps": [
    {
      "id": "wechat",
      "name": "WeChat",
      "vendor": "Tencent",
      "category": "chat",
      "risk_level": "medium",
      "paths": [
        "%APPDATA%\\Tencent\\WeChat",
        "%LOCALAPPDATA%\\Tencent\\WeChat",
        "%LOCALAPPDATA%\\WeChat"
      ],
      "exclude_paths": [
        "%USERPROFILE%\\Documents\\WeChat Files"
      ],
      "rules": [
        {
          "type": "dir_name",
          "include": ["Cache", "Code Cache", "GPUCache", "Temp", "Logs", "Crashpad", "XWeb"],
          "exclude": ["Storage", "Local Storage", "IndexedDB", "Session Storage"],
          "delete_safe": true,
          "category": "cache"
        }
      ],
      "notes": "WeChat Files usually contains user attachments and exported data."
    },
