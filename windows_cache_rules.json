{
  "version": "1.1.0",
  "platform": "windows",
  "description": "Cache scanning rules for common Windows desktop applications, including Chinese domestic software.",
  "variables": {
    "%USERPROFILE%": "C:\\Users\\{username}",
    "%LOCALAPPDATA%": "C:\\Users\\{username}\\AppData\\Local",
    "%APPDATA%": "C:\\Users\\{username}\\AppData\\Roaming",
    "%PROGRAMDATA%": "C:\\ProgramData",
    "%PROGRAMFILES%": "C:\\Program Files",
    "%PROGRAMFILES(X86)%": "C:\\Program Files (x86)",
    "%PUBLIC%": "C:\\Users\\Public",
    "%SYSTEMROOT%": "C:\\Windows",
    "%TEMP%": "C:\\Users\\{username}\\AppData\\Local\\Temp"
  },
  "global_rules": {
    "default_follow_symlink": false,
    "default_include_hidden": true,
    "default_min_file_age_minutes": 10,
    "default_exclude_extensions": [
      ".db",
      ".sqlite",
      ".sqlite3",
      ".ldb",
      ".sst",
      ".logdb"
    ],
    "default_exclude_file_names": [
      "Bookmarks",
      "Bookmarks.bak",
      "Cookies",
      "Cookies-journal",
      "Current Session",
      "Current Tabs",
      "Favicons",
      "History",
      "History-journal",
      "Last Session",
      "Last Tabs",
      "Login Data",
      "Login Data For Account",
      "Network Persistent State",
      "Preferences",
      "Secure Preferences",
      "Session Storage",
      "Top Sites",
      "Visited Links",
      "Web Data"
    ],
    "safe_dir_name_patterns": [
      "Cache",
      "Caches",
      "Code Cache",
      "GPUCache",
      "GrShaderCache",
      "ShaderCache",
      "Temp",
      "Tmp",
      "Logs",
      "Crashpad",
      "CrashDumps",
      "Dumps",
      "blob_storage",
      "Service Worker\\CacheStorage"
    ]
  },
  "cleanup_catalog": [
    {
      "id": "software_specific_cleanup",
      "name": "软件专清",
      "description": "Competitor-inspired Windows cleanup catalog for product landing. These items are intended for UI presentation and rule planning.",
      "items": [
        {
          "id": "microsoft_products",
          "name": "微软产品",
          "sub_items": [
            {
              "name": "Microsoft Office 升级文件",
              "directories": [
                "%SYSTEMROOT%\\Installer",
                "C:\\MSOCache"
              ],
              "delete_risk": "medium",
              "default_checked": false
            },
            {
              "name": "Microsoft Office 最近使用文件列表",
              "directories": [
                "%APPDATA%\\Microsoft\\Office\\Recent"
              ],
              "delete_risk": "low",
              "default_checked": true
            },
            {
              "name": "Windows Defender 隔离文件",
              "directories": [
                "%PROGRAMDATA%\\Microsoft\\Windows Defender\\Quarantine"
              ],
              "delete_risk": "high",
              "default_checked": false
